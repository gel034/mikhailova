<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Astral — магазин манг</title>
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
    }

    body {
      background: #fce4ec;
      color: #3b1515;
    }

    .app {
      max-width: 1440px;
      margin: 0 auto;
      background: #fff5f7;
      min-height: 100vh;
      box-shadow: 0 0 30px rgba(150, 50, 70, 0.06);
    }

    /* ----- ХЕДЕР (общий) ----- */
    .header {
      background: #b0304a;
      padding: 14px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px 20px;
      box-shadow: 0 4px 12px rgba(140, 30, 50, 0.2);
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .brand {
      font-size: 28px;
      font-weight: 800;
      letter-spacing: 2px;
      color: #ffd9e1;
      text-shadow: 0 2px 4px rgba(90, 10, 30, 0.3);
    }
    .brand i {
      margin-right: 6px;
      color: #ffb6c9;
    }

    .search-bar {
      flex: 1 1 280px;
      display: flex;
      background: #fff0f3;
      border-radius: 40px;
      padding: 4px 8px 4px 18px;
      align-items: center;
      border: 1px solid #d97a8a;
      transition: 0.2s;
      max-width: 500px;
    }
    .search-bar:focus-within {
      border-color: #ff4d6d;
      box-shadow: 0 0 0 3px rgba(255, 77, 109, 0.2);
    }
    .search-bar input {
      border: none;
      background: transparent;
      padding: 10px 4px;
      font-size: 16px;
      width: 100%;
      outline: none;
      color: #2d0a0a;
    }
    .search-bar input::placeholder {
      color: #a05a6a;
      font-weight: 300;
    }
    .search-bar button {
      background: #b0304a;
      border: none;
      border-radius: 40px;
      padding: 8px 18px;
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: 0.15s;
      font-size: 15px;
    }
    .search-bar button:hover {
      background: #8f1f37;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .header-actions .icon-btn {
      background: rgba(255, 255, 255, 0.1);
      border: none;
      color: #ffd9e1;
      font-size: 24px;
      width: 44px;
      height: 44px;
      border-radius: 40px;
      cursor: pointer;
      transition: 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .header-actions .icon-btn:hover {
      background: rgba(255, 255, 255, 0.25);
      color: #fff;
      transform: scale(1.03);
    }

    /* ----- ФРЕЙМЫ ----- */
    .frame {
      display: none;
      padding: 24px 28px 40px;
      animation: fade 0.2s ease;
    }
    .frame.active {
      display: block;
    }

    @keyframes fade {
      0% { opacity: 0.6; transform: translateY(6px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* ----- БАННЕР (зеленый) ----- */
    .banner-green {
      background: #d4edda;
      border-radius: 28px;
      padding: 20px 28px;
      margin-bottom: 36px;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      border: 1px solid #b7d7b7;
      box-shadow: 0 6px 14px rgba(60, 120, 60, 0.08);
    }
    .banner-green h2 {
      color: #1e4a1e;
      font-size: 22px;
      font-weight: 700;
    }
    .banner-green h2 i {
      color: #2d7a2d;
      margin-right: 12px;
    }
    .banner-green .btn-banner {
      background: #2d7a2d;
      border: none;
      padding: 14px 34px;
      border-radius: 60px;
      color: white;
      font-weight: 700;
      font-size: 18px;
      cursor: pointer;
      transition: 0.15s;
      border: 1px solid #3d8a3d;
    }
    .banner-green .btn-banner:hover {
      background: #1e5e1e;
      transform: scale(1.02);
    }

    /* ----- КАТАЛОГ (сетка) ----- */
    .catalog-layout {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 30px 40px;
      margin-top: 12px;
    }

    .sidebar {
      flex: 0 0 210px;
      background: #fce4ea;
      border-radius: 32px;
      padding: 24px 16px;
      height: fit-content;
      border: 1px solid #ebc2cc;
    }
    .sidebar h3 {
      color: #751f33;
      font-size: 20px;
      margin-bottom: 20px;
      border-bottom: 2px solid #d97a8a;
      padding-bottom: 10px;
    }
    .sidebar ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .sidebar li {
      font-weight: 500;
      color: #5f2a36;
      padding: 6px 6px 6px 12px;
      border-radius: 40px;
      background: rgba(255, 215, 225, 0.4);
      font-size: 15px;
      cursor: default;
    }
    .sidebar li i {
      margin-right: 10px;
      color: #b0304a;
      width: 18px;
    }

    .manga-grid {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 30px 20px;
      width: 100%;
    }

    .manga-card {
      background: white;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 0 4px 12px rgba(140, 50, 70, 0.08);
      transition: 0.2s;
      border: 1px solid #f0d3db;
      display: flex;
      flex-direction: column;
      cursor: pointer;
    }
    .manga-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 14px 28px rgba(180, 50, 70, 0.15);
    }
    .manga-card img {
      width: 100%;
      aspect-ratio: 2/3;
      object-fit: cover;
      background: #d6b7bf;
      border-bottom: 2px solid #f0ced6;
    }
    .manga-info {
      padding: 14px 14px 18px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .manga-info h4 {
      font-size: 16px;
      color: #3b1515;
      line-height: 1.3;
      margin-bottom: 4px;
    }
    .manga-info .author {
      font-size: 13px;
      color: #7a4a4a;
      margin-bottom: 10px;
    }
    .manga-info .price {
      font-weight: 700;
      color: #b0304a;
      font-size: 17px;
      margin: 6px 0 8px;
    }
    .btn-buy {
      background: #b0304a;
      border: none;
      padding: 10px 0;
      border-radius: 60px;
      color: white;
      font-weight: 700;
      cursor: pointer;
      transition: 0.15s;
      font-size: 15px;
      margin-top: auto;
      border: 1px solid #c03e5a;
    }
    .btn-buy:hover {
      background: #8f1f37;
    }

    /* фильтр */
    .filter-bar {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 12px 20px;
      margin-bottom: 28px;
      background: #fce4ea;
      padding: 10px 24px;
      border-radius: 60px;
      border: 1px solid #ebc2cc;
      width: 100%;
    }
    .filter-bar span {
      font-weight: 600;
      color: #5f2a36;
      margin-right: 4px;
    }
    .filter-btn {
      background: transparent;
      border: 1px solid #bc6f7e;
      padding: 6px 18px;
      border-radius: 60px;
      font-weight: 500;
      color: #4a1a1a;
      cursor: pointer;
      transition: 0.1s;
      font-size: 14px;
    }
    .filter-btn:hover {
      background: #b0304a;
      color: white;
      border-color: #b0304a;
    }

    /* стрелка назад */
    .back-arrow {
      font-size: 28px;
      background: #f0d3db;
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 40px;
      cursor: pointer;
      transition: 0.15s;
      color: #5f2a36;
      border: none;
      margin-bottom: 16px;
    }
    .back-arrow:hover {
      background: #d97a8a;
      color: white;
    }

    .frame2-head {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
      width: 100%;
    }
    .frame2-head h2 {
      color: #751f33;
      font-weight: 700;
      font-size: 26px;
    }

    /* связь с нами */
    .contact-section {
      margin-top: 50px;
      background: #fce4ea;
      padding: 30px 32px;
      border-radius: 48px;
      border: 1px solid #dbb7c2;
    }
    .contact-section h3 {
      color: #751f33;
      font-size: 28px;
      margin-bottom: 12px;
    }
    .contact-section p {
      font-size: 18px;
      color: #3b1a1a;
    }
    .contact-section i {
      color: #b0304a;
      width: 30px;
    }

    /* Модалка профиля */
    .profile-modal {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(40, 10, 20, 0.5);
      backdrop-filter: blur(4px);
      align-items: center;
      justify-content: center;
      z-index: 999;
    }
    .profile-modal.open {
      display: flex;
    }
    .modal-box {
      background: #fff5f7;
      max-width: 420px;
      width: 90%;
      padding: 36px 28px;
      border-radius: 48px;
      box-shadow: 0 30px 50px rgba(100, 20, 40, 0.3);
      border: 1px solid #dbb7c2;
      animation: fade 0.25s;
    }
    .modal-box h3 {
      color: #751f33;
      font-size: 22px;
      margin-bottom: 20px;
    }
    .modal-box label {
      font-weight: 600;
      color: #4a1a1a;
      display: block;
      margin: 16px 0 6px;
    }
    .modal-box input {
      width: 100%;
      padding: 14px 18px;
      border-radius: 60px;
      border: 1px solid #d97a8a;
      font-size: 16px;
      background: white;
    }
    .modal-box input:focus {
      outline: 2px solid #b0304a;
    }
    .modal-btn {
      background: #b0304a;
      border: none;
      padding: 14px;
      width: 100%;
      border-radius: 60px;
      color: white;
      font-weight: 700;
      font-size: 18px;
      margin-top: 20px;
      cursor: pointer;
      transition: 0.15s;
    }
    .modal-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .modal-btn:hover:not(:disabled) {
      background: #8f1f37;
    }
    .modal-close {
      text-align: right;
      font-size: 28px;
      cursor: pointer;
      color: #751f33;
      margin-top: -8px;
    }

    /* корзина (модалка) */
    .cart-modal {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(40, 10, 20, 0.5);
      backdrop-filter: blur(4px);
      align-items: center;
      justify-content: center;
      z-index: 999;
    }
    .cart-modal.open {
      display: flex;
    }

    /* адаптив */
    @media (max-width: 700px) {
      .header { flex-direction: column; align-items: stretch; }
      .header-actions { justify-content: flex-end; }
      .sidebar { flex: 1 1 100%; }
    }
  </style>
</head>
<body>
<div class="app">

  <!-- ШАПКА -->
  <header class="header">
    <div class="header-left">
      <span class="brand"><i class="fas fa-star"></i> Astral</span>
    </div>
    <div class="search-bar">
      <input type="text" placeholder="Поиск книг, авторов">
      <button><i class="fas fa-search"></i></button>
    </div>
    <div class="header-actions">
      <button class="icon-btn" id="cartBtn"><i class="fas fa-shopping-cart"></i></button>
      <button class="icon-btn" id="profileBtn"><i class="fas fa-user-circle"></i></button>
    </div>
  </header>

  <!-- ===== ФРЕЙМ 1 ===== -->
  <div class="frame active" id="frame1">
    <!-- Зелёный баннер -->
    <div class="banner-green">
      <h2><i class="fas fa-leaf"></i> “Магическая битва”, “Человек бензопила” и другие популярные книги</h2>
      <button class="btn-banner" onclick="switchFrame(2)">Выбрать сюжет →</button>
    </div>

    <div class="catalog-layout">
      <aside class="sidebar">
        <h3><i class="fas fa-book-open"></i> Каталог</h3>
        <ul>
          <li><i class="fas fa-layer-group"></i> Комиксы и манга</li>
          <li><i class="fas fa-book"></i> Манга</li>
          <li><i class="fas fa-dragon"></i> Руманга</li>
          <li><i class="fas fa-globe"></i> Манга исекай</li>
          <li><i class="fas fa-mask"></i> Манга сёнэн</li>
          <li><i class="fas fa-heart"></i> Манга сёдзё</li>
          <li><i class="fas fa-rainbow"></i> Манга романтика</li>
          <li><i class="fas fa-laugh"></i> Манга комедия</li>
          <li><i class="fas fa-ghost"></i> Манга ужасы</li>
          <li><i class="fas fa-fist-raised"></i> Манга драма</li>
          <li><i class="fas fa-hat-wizard"></i> Манга фэнтези</li>
          <li><i class="fas fa-ellipsis-h"></i> Другие жанры</li>
          <li><i class="fas fa-tag"></i> Тематическая манга</li>
          <li><i class="fas fa-pen-fancy"></i> OEL-манга</li>
        </ul>
      </aside>

      <div class="manga-grid">
        <!-- Атака титанов -->
        <div class="manga-card" onclick="showMangaInfo('Атака титанов. Том 33, 34 (Attack on Titan). Манга Хадзимэ Исаяма', 'Покинувшие Парадиз титаны уничтожают всё на своём пути. Микаса, Армин и остальные готовятся к последнему бою. Смогут ли они спасти человечество?')">
          <img src="https://img-gorod.ru/upload/iblock/95d/95d9b7b5e6f8e6d2b3c4d5e6f7a8b9c0.jpg?width=400" alt="Атака титанов">
          <div class="manga-info">
            <h4>Атака титанов. Том 33, 34</h4>
            <div class="author">Хадзимэ Исаяма</div>
            <div class="price">1 474₽ <span style="text-decoration:line-through; color:#a05a6a; font-weight:400;">1 252₽</span></div>
            <button class="btn-buy" onclick="event.stopPropagation(); alert('Добавлено в корзину!')">Купить</button>
          </div>
        </div>
        <!-- Магическая битва 11-12 -->
        <div class="manga-card" onclick="showMangaInfo('Магическая битва. Том 11, 12 — Инцидент в Сибуе. Гэгэ Акутами', 'Инцидент в Сибуе перерастает в хаос. Маги вступают в битву с проклятиями. Сукуна пробуждается...')">
          <img src="https://img-gorod.ru/upload/iblock/1a2/1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d.jpg?width=400" alt="Магическая битва">
          <div class="manga-info">
            <h4>Магическая битва. Том 11, 12</h4>
            <div class="author">Гэгэ Акутами</div>
            <div class="price">1 364₽ <span style="text-decoration:line-through; color:#a05a6a; font-weight:400;">1 159₽</span></div>
            <button class="btn-buy" onclick="event.stopPropagation(); alert('Добавлено в корзину!')">Купить</button>
          </div>
        </div>
        <!-- Токийский гуль -->
        <div class="manga-card" onclick="showMangaInfo('Токийский гуль. Том 1, 2 (Tokyo Ghoul). Манга Суи Исида', 'Кэн Канэки становится наполовину гулем. Ему предстоит выживать в мире, где люди и гули ведут войну.')">
          <img src="https://img-gorod.ru/upload/iblock/3c4/3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f.jpg?width=400" alt="Токийский гуль">
          <div class="manga-info">
            <h4>Токийский гуль. Том 1, 2</h4>
            <div class="author">Суи Исида</div>
            <div class="price">1 874₽ <span style="text-decoration:line-through; color:#a05a6a; font-weight:400;">1 499₽</span></div>
            <button class="btn-buy" onclick="event.stopPropagation(); alert('Добавлено в корзину!')">Купить</button>
          </div>
        </div>
        <!-- Человек-бензопила -->
        <div class="manga-card" onclick="showMangaInfo('Человек-бензопила. Том 15 — Два ребенка... Тацуки Фудзимото', 'Дэндзи и его команда сталкиваются с новыми врагами. Битва с демонами продолжается.')">
          <img src="https://img-gorod.ru/upload/iblock/5d6/5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a.jpg?width=400" alt="Человек-бензопила">
          <div class="manga-info">
            <h4>Человек-бензопила. Том 15</h4>
            <div class="author">Тацуки Фудзимото</div>
            <div class="price">1 896₽ <span style="text-decoration:line-through; color:#a05a6a; font-weight:400;">1 399₽</span></div>
            <button class="btn-buy" onclick="event.stopPropagation(); alert('Добавлено в корзину!')">Купить</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== ФРЕЙМ 2 ===== -->
  <div class="frame" id="frame2">
    <div class="frame2-head">
      <button class="back-arrow" onclick="switchFrame(1)"><i class="fas fa-arrow-left"></i></button>
      <h2>Манга: боевик, фэнтези</h2>
    </div>

    <div class="catalog-layout" style="margin-top: 12px;">
      <aside class="sidebar">
        <h3><i class="fas fa-filter"></i> Каталог</h3>
        <ul>
          <li><i class="fas fa-layer-group"></i> Комиксы и манга</li>
          <li><i class="fas fa-book"></i> Манга</li>
          <li><i class="fas fa-dragon"></i> Руманга</li>
          <li><i class="fas fa-globe"></i> Манга исекай</li>
          <li><i class="fas fa-mask"></i> Манга сёнэн</li>
          <li><i class="fas fa-heart"></i> Манга сёдзё</li>
          <li><i class="fas fa-rainbow"></i> Манга романтика</li>
          <li><i class="fas fa-laugh"></i> Манга комедия</li>
          <li><i class="fas fa-ghost"></i> Манга ужасы</li>
          <li><i class="fas fa-fist-raised"></i> Манга драма</li>
          <li><i class="fas fa-hat-wizard"></i> Манга боевик</li>
          <li><i class="fas fa-hat-wizard"></i> Манга фэнтези</li>
          <li><i class="fas fa-ellipsis-h"></i> Другие жанры</li>
          <li><i class="fas fa-tag"></i> Тематическая манга</li>
          <li><i class="fas fa-pen-fancy"></i> OEL-манга</li>
        </ul>
      </aside>

      <div style="flex:1">
        <!-- фильтр -->
        <div class="filter-bar">
          <span><i class="fas fa-sliders-h"></i> Сортировка:</span>
          <button class="filter-btn" onclick="alert('По популярности')">По популярности</button>
          <button class="filter-btn" onclick="alert('По новизне')">По новизне</button>
          <button class="filter-btn" onclick="alert('Сначала дешёвые')">Сначала дешёвые</button>
          <button class="filter-btn" onclick="alert('Сначала дорогие')">Сначала дорогие</button>
          <button class="filter-btn" onclick="alert('По рейтингу')">По рейтингу</button>
          <button class="filter-btn" onclick="alert('Больше отзывов')">Больше отзывов</button>
        </div>

        <div class="manga-grid">
          <!-- Катастрофа по соседству -->
          <div class="manga-card" onclick="showMangaInfo('Катастрофа по соседству. Том 1. Манга Сугахара Кэйта', 'Невероятные события происходят в тихом городке. Сосед оказывается не тем, кем кажется.')">
            <img src="https://img-gorod.ru/upload/iblock/7e8/7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b.jpg?width=400" alt="Катастрофа по соседству">
            <div class="manga-info">
              <h4>Катастрофа по соседству. Том 1</h4>
              <div class="author">Сугахара Кэйта</div>
              <div class="price">995₽ <span style="text-decoration:line-through; color:#a05a6a; font-weight:400;">829₽</span></div>
              <button class="btn-buy" onclick="event.stopPropagation(); alert('Добавлено в корзину!')">Купить</button>
            </div>
          </div>
